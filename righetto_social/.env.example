# Dashboard Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# service_role (consigliato sul PC/server) oppure anon (solo test in locale)
SUPABASE_KEY=

# ── Meta (UNICA configurazione FB+IG — non duplicare nell'admin) ──
META_GRAPH_VERSION=v21.0
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=

AGENDA_TIMEZONE=Europe/Rome
PUBLISH_WINDOW_MINUTES=120

GENERA_REEL_AUTO=0
# FFMPEG_PATH=C:\...\ffmpeg.exe
REEL_STORAGE_BUCKET=foto-immobili
REEL_MUSIC_VOLUME=0.22

# ── Google Business Profile (Gruppo Immobiliare Righetto — Maps) ──
# OAuth scope business.manage — token da Admin > Connetti Google Business, poi incolla qui
GOOGLE_GBP_ACCESS_TOKEN=
# Formato: accounts/ACCOUNT_ID/locations/LOCATION_ID (vedi connectGBP in admin)
GOOGLE_GBP_PARENT=
# Replica post/reel Meta anche su GBP (1=sì, 0=no). Le notizie RSS hanno righe tipo=google dedicate.
GBP_MIRROR_META=1
