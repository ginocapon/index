# ── Cache lunga per risorse statiche ──
<IfModule mod_expires.c>
  ExpiresActive On

  # Immagini: 1 anno
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Font: 1 anno
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS/JS: 1 anno (cache-busting via ?v= nei riferimenti HTML)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"

  # HTML: no cache (sempre fresco)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── Cache-Control headers ──
<IfModule mod_headers.c>
  # Immagini e font: immutabili, 1 anno
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS e JS: 1 anno (cache-busting via ?v= nei riferimenti HTML)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML: no cache
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Compressione Gzip ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json image/svg+xml font/woff2 application/font-woff2
</IfModule>

# ── Security Headers ──
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ── ETag disabilitato (usa Cache-Control) ──
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# ── Redirect www → non-www ──
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.righettoimmobiliare\.it$ [NC]
  RewriteRule ^(.*)$ https://righettoimmobiliare.it/$1 [R=301,L]
</IfModule>

# ── SEO redirects (build_seo_redirects.py) ──
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Trailing slash → senza slash (pagine .html)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]
  RewriteRule ^agenzia$ /agenzia-immobiliare-padova [R=301,L]
  RewriteRule ^agenzia\.html$ /agenzia-immobiliare-padova [R=301,L]
  RewriteRule ^api/$ /contatti [R=301,L]
  RewriteRule ^api/send-mail\.php$ /contatti [R=301,L]
  RewriteRule ^blog-affitti-canoni-fimaa-q1-2024-padova$ /blog-affitti-canoni-fimaa-q1-2026-padova [R=301,L]
  RewriteRule ^blog-bonus-edilizi-2024-incentivi-casa-padova$ /blog-bonus-edilizi-2026-incentivi-casa-padova [R=301,L]
  RewriteRule ^blog-piano-casa-decreto-salva-casa-padova$ /blog-piano-casa-decreto-66-2026-padova [R=301,L]
  RewriteRule ^blog-vigonza-rubano-comprare-casa-cintura-2024$ /blog-vigonza-rubano-comprare-casa-cintura-2026 [R=301,L]
  RewriteRule ^blog\.html$ /blog [R=301,L]
  RewriteRule ^blog/$ /blog [R=301,L]
  RewriteRule ^chi-siamo\.html$ /chi-siamo [R=301,L]
  RewriteRule ^chi-siamo/$ /chi-siamo [R=301,L]
  RewriteRule ^contatti\.html$ /contatti [R=301,L]
  RewriteRule ^contatti/$ /contatti [R=301,L]
  RewriteRule ^cookie-policy\.html$ /cookie-policy [R=301,L]
  RewriteRule ^home$ / [R=301,L]
  RewriteRule ^home\.html$ / [R=301,L]
  RewriteRule ^immobile\.html$ /immobile [R=301,L]
  RewriteRule ^immobili\.html$ /immobili [R=301,L]
  RewriteRule ^immobili\.php$ /immobili [R=301,L]
  RewriteRule ^immobili/$ /immobili [R=301,L]
  RewriteRule ^index\.html$ / [R=301,L]
  RewriteRule ^index\.php$ / [R=301,L]
  RewriteRule ^privacy-policy\.html$ /privacy-policy [R=301,L]
  RewriteRule ^privacy\.html$ /privacy-policy [R=301,L]
  RewriteRule ^righetto$ / [R=301,L]
  RewriteRule ^righetto\.html$ / [R=301,L]
  RewriteRule ^servizi\.html$ /servizi [R=301,L]
  RewriteRule ^servizi/$ /servizi [R=301,L]
  RewriteRule ^wp-admin$ / [R=301,L]
  RewriteRule ^wp-admin/$ / [R=301,L]
  RewriteRule ^wp-login\.php$ / [R=301,L]
</IfModule>
# ── Fine SEO redirects ──
