# ── Cache lunga per risorse statiche ──
<IfModule mod_expires.c>
  ExpiresActive On

  # Immagini: 1 anno
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Font: 1 anno
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS/JS: 1 mese
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"

  # HTML: no cache (sempre fresco)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── Cache-Control headers ──
<IfModule mod_headers.c>
  # Immagini e font: immutabili, 1 anno
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS e JS: 1 mese
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML: no cache
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Compressione Gzip ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json image/svg+xml font/woff2 application/font-woff2
</IfModule>

# ── Redirect www → non-www ──
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.righettoimmobiliare\.it$ [NC]
  RewriteRule ^(.*)$ https://righettoimmobiliare.it/$1 [R=301,L]
</IfModule>
